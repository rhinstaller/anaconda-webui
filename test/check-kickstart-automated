class TestKickstartAutomatedPause(VirtInstallMachineCase):
    """Destructive tests for kickstart-driven automated installations."""

    provision = {
        "machine1": {
            "kickstart_file_name": "TestKickstartAutomatedPause-testBasic.ks",
            "payload_type": "dnf",
            "memory_mb": INSTALLER_VM_MEMORY_MB,
            "pause_at_summary": True,
        },
    }

    def testBasic(self):
        """
        Description:
            Boot with ``inst.ks=TestKickstartAutomatedPause-testBasic.ks``
            with inst.pauseatsummary option.

        Expected results:
            - Automated install pause on the review step with the install action enabled.
            - Users specified in kickstart are correctly picked up on the Accounts step
              and cannot be changed.
            - Root settings cannot be changed when rootpw is in kickstart.
            - Timezone and timesource lines from kickstart appear on the date & time screen;
              NTP servers, pool, and NTS options are visible in the Configure NTP servers modal.
            - Scenario is preset to 'Use configured storage' and the partitioning appears on the Review storage section.
            - Environment and groups from the ``%packages`` section in the kickstart appear on the Software selection step.
        """
        b = self.browser
        m = self.machine
        i = Installer(b, m, scenario="use-configured-storage-kickstart")
        u = Users(b, m)
        dt = DateAndTime(b, m)
        r = Review(b, m)
        s = Storage(b, m)

        b.open("/cockpit/@localhost/anaconda-webui/index.html")
        b.wait_visible("#installation-next-btn:not([aria-disabled=true])")

        i.reach_on_sidebar(i.steps.LANGUAGE)
        i.reach(i.steps.DATE_TIME)

        tz = dt.dbus_get_timezone()
        region, city = tz.split("/", 1)
        dt.check_region(region)
        dt.check_city(city)
        dt.check_auto_date_time(dt.dbus_get_ntp_enabled())
        dt.check_ntp_modal_rows([
            {"hostname": "ntp.cesnet.cz", "pool": False, "nts": False},
            {"hostname": "nts-test.strangled.net", "pool": False, "nts": True},
            {"hostname": "0.pool.ntp.org", "pool": True, "nts": False},
        ])

        i.reach(i.steps.SOFTWARE_SELECTION)
        dnf = PayloadDNF(b)
        dnf.check_selected_environment("workstation-product-environment")
        dnf.check_group_selected("domain-client")

        i.reach(i.steps.INSTALLATION_METHOD)
        s.check_scenario_selected("use-configured-storage-kickstart")

        i.reach(i.steps.ACCOUNTS)

        # Verify kickstart users (read-only) and locked root
        u.check_readonly_users_section_visible()
        u.check_readonly_user_displayed("alice", full_name="Alice Admin")
        u.check_readonly_user_displayed("bob", full_name="Bob User")
        u.check_readonly_user_displayed("carol", full_name="Carol Dev")
        b.wait_visible("#anaconda-screen-accounts-root-account-enable-root-account:disabled")
        b.assert_pixels(".anaconda-wizard-step-anaconda-screen-accounts", "users-kickstarted", ignore=pixel_tests_ignore)

        i.reach(i.steps.REVIEW)

        r.check_storage_config("Use configured storage")
        dev1 = "vda"
        r.check_disk(dev1, "16.1 GB vda (Virtio Block Device)")
        r.check_disk_row(dev1, "/boot/efi", "vda1", EFI_PARTITION_DEFAULT_SIZE_MB, True, "efi")
        r.check_disk_row(dev1, "/", "vda5", "11.2 GB", True, "xfs")
        r.check_disk_row(dev1, "/boot", "vda2", "1.15 GB", True, "xfs")
        r.check_disk_row(dev1, "/home", "vda3", "2.15 GB", True, "xfs")
        r.check_disk_row(dev1, "swap", "vda4", "1.07 GB", True, "swap")

        i.check_next_disabled(disabled=False)
        b.assert_pixels(".anaconda-wizard-step-anaconda-screen-review", "review-kickstarted", ignore=pixel_tests_ignore)

    def testUserInterfaceCanChangeAccountsConf(self):
        """
        Description:
            Non-default ``can_change_root`` and ``can_change_users`` in ``anaconda.conf``
            (both ``True``): root must stay interactive and the user section must show the
            editable create-account UI instead of the kickstart read-only summary.

        Expected results:
            - Read-only kickstart user summary is not shown; create-account controls are present
            - Root enable checkbox is not disabled
        """
        b = self.browser
        m = self.machine
        i = Installer(b, m, scenario="use-configured-storage-kickstart")

        override_user_interface_conf_keys(self, can_change_root=True, can_change_users=True)
        b.open("/cockpit/@localhost/anaconda-webui/index.html")
        b.wait_visible("#installation-next-btn:not([aria-disabled=true])")
        i.reach_on_sidebar(i.steps.ACCOUNTS)

        b.wait_visible("#anaconda-screen-accounts-root-account-enable-root-account:not(:disabled)")
        b.wait_visible("#anaconda-screen-accounts-create-account-set-user-account:not(:disabled)")


